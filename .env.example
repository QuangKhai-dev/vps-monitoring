# PostgreSQL — cùng pattern với các service NestJS trong monorepo
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vps_monitoring
DB_DATABASE=vps_monitoring
DB_USER=admin
DB_USERNAME=admin
DB_PASSWORD=")80s;M5MuRA{"

# Hoặc một dòng (ưu tiên hơn DB_* nếu có):
# DATABASE_URL=postgresql://admin:password@localhost:5432/vps_monitoring

# Trong docker-compose gốc (service `postgres`): DB_HOST=postgres

# JWT secret (generate: openssl rand -hex 64)
JWT_SECRET=replace-me-with-a-long-random-string-please-change-this

# Public URL where this dashboard is hosted (used by install script)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: seconds before an agent is considered offline
AGENT_OFFLINE_AFTER_SECONDS=60

# Telegram overload alerts: configure in the web UI (Settings), stored in PostgreSQL.
